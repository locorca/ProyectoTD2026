library(nloptr)
# Definición de la función
f_Ros <- function(x) {
return( 100 * (x[2] - x[1]^2)^2 + (1 - x[1])^2 )
}
# Definición del gradiente
grad_Ros <- function(x) {
return( c( -400 * x[1] * (x[2] - x[1]^2) - 2 * (1 - x[1]),200 * (x[2] - x[1]^2) ) )
}
# Punto inicial
x_inicial <- c( -1.2, 1 )
# Opciones: ponemos el algoritmo a utilizar y el criterio de parada
# En este caso, usará LBFGS
opciones <- list("algorithm"="NLOPT_LD_LBFGS", "maxeval"=1000, "xtol_rel"=1.0e-6)
# llamada a la función
res <- nloptr( x0=x_inicial, eval_f=f_Ros, eval_grad_f=grad_Ros, opts=opciones)
#imprimir el resultado
print (res)
#Definición de la función
f_Hock <- function( x ) {
return(  x[1]*x[4]*(x[1] + x[2] + x[3]) + x[3])  }
#Definición del gradiente de la función
grad_Hock <- function( x )
{
return(c(x[4]*(x[1] + x[2] + x[3])+x[1]*x[4],
x[1]*x[4],
x[1]*x[4]+1,
x[1]*(x[1] + x[2] + x[3]))  )
}
# Definición de las restricciones de desigualdad
desig_Hock <- function( x ) {
constr <- c( 25 - x[1] * x[2] * x[3] * x[4] )
return( constr )
}
# Definición del jacobiano de las restricciones de desigualdad
grad_desig_Hock <- function(x)
{
return(c(-x[2]*x[3]*x[4],
-x[1]*x[3]*x[4],
-x[1]*x[2]*x[4],
-x[1]*x[2]*x[3])  )
}
# Definición de las restricciones de igualdad
igual_Hock <- function( x ) {
constr <- c( x[1]^2 + x[2]^2 + x[3]^2 + x[4]^2 - 40 )
return( constr)
}
# Definición del jacobiano de las restricciones de igualdad
grad_igual_Hock <- function(x)
{
return(c(2*x[1],
2*x[2],
2*x[3],
2*x[4])  )
}
# Punto inicial
x_inicial <- c( 1, 5, 5, 1 )
# Cotas inferiores y superiores para las variables
cota_inf <- c( 1, 1, 1, 1 )
cota_sup <- c( 5, 5, 5, 5 )
# Opciones (en este caso, usaremos el Metodo de la Lagrangiana Aumentada)
# Opciones locales (el método de la Lagangiana Aumentada necesita un optimizador local,
# en este caso un método Quasi-Newton)
opciones_locales <- list( "algorithm" = "NLOPT_LD_LBFGS",
"maxeval"=5000,"xtol_rel"=1.0e-6)
opciones <- list( "algorithm" = "NLOPT_LD_AUGLAG",
"maxeval"   = 5000,
"xtol_rel"=1.0e-6,
"local_opts"=opciones_locales,
"print_level"=0)
# Llamada a la función
res <- nloptr( x0=x_inicial,
eval_f=f_Hock,
eval_grad_f = grad_Hock,
lb=cota_inf,
ub=cota_sup,
eval_g_ineq=desig_Hock,
eval_jac_g_ineq=grad_desig_Hock,
eval_g_eq=igual_Hock,
eval_jac_g_eq=grad_igual_Hock,
opts=opciones
)
#Imprimir el resultado
print(res)
library(nloptr)
# 1. Función objetivo (Minimizar -F)
eval_f <- function(x) { return(-x[6]) }
# 2. Restricciones de igualdad (Nodos)
eval_g_eq <- function(x) {
h <- c(x[6] - x[1] - x[2],      # Nodo 1
x[1] + x[3] - x[4],      # Nodo 2
x[2] - x[3] - x[5])      # Nodo 3
return(h)
}
# 3. Configuración y ejecución
x0 <- c(10, 10, 10, 10, 10, 10)   # Punto inicial [cite: 207]
lb <- rep(0, 6)                   # Cotas inferiores
ub <- c(15, 20, 15, 20, 15, Inf)  # Capacidades máximas [cite: 202]
# Algoritmo sin derivadas (AUGLAG + NELDERMEAD)
local_opts <- list("algorithm" = "NLOPT_LN_NELDERMEAD",
"xtol_rel" = 1.0e-6,
"maxeval" = 100000)
opts <- list("algorithm" = "NLOPT_LN_AUGLAG",
"local_opts" = local_opts,
"xtol_rel" = 1.0e-6,
"maxeval" = 100000, # Límite alto
"print_level" = 1)
res <- nloptr(x0=x0, eval_f=eval_f, lb=lb, ub=ub, eval_g_eq=eval_g_eq, opts=opts)
# 4. Resultado
print(res)
knitr::opts_chunk$set(echo = TRUE)
algoritmo_constructivo <- function(valores, pesos, cap1, cap2) {
n <- length(valores)
ratios <- valores / pesos
orden <- order(ratios, decreasing = TRUE)
maleta1 <- c() # Vector de objetos en maleta 1
maleta2 <- c() # Vector de objetos en maleta 2
peso_actual1 <- 0
peso_actual2 <- 0
for (i in orden) {
if (peso_actual1 + pesos[i] <= cap1) {
maleta1 <- c(maleta1, i)
peso_actual1 <- peso_actual1 + pesos[i]
} else if (peso_actual2 + pesos[i] <= cap2) {
maleta2 <- c(maleta2, i)
peso_actual2 <- peso_actual2 + pesos[i]
}
}
return(list(
objetos_maleta1 = maleta1,
objetos_maleta2 = maleta2,
valor_total = sum(valores[c(maleta1, maleta2)])
))
}
pesos_obj <- c(10, 9, 15, 3, 11, 6, 3, 4)
valores_obj <- c(5, 2, 7, 6, 10, 6, 8, 6)
cap_m1 <- 18
cap_m2 <- 27
resultado <- algoritmo_constructivo(valores_obj, pesos_obj, cap_m1, cap_m2)
resultado
