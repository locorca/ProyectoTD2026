library(tidyverse)
library(lubridate)
library(knitr)
options(OutDec = ",", digits = 3)
knitr::opts_chunk$set(echo = FALSE, warning = FALSE, message = FALSE)
logs_raw <- read.csv("data/logs_moodle_anon.csv", sep = ",", stringsAsFactors = FALSE)
logs <- logs_raw %>%
mutate(
Fecha_Completa = dmy_hms(Hora),
Solo_Fecha = as.Date(Fecha_Completa),
Hora_num = hour(Fecha_Completa),
Dia_semana_num = wday(Fecha_Completa, week_start = 1),
Dia_semana = factor(
c("Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")[Dia_semana_num],
levels = c("Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
),
Semana = isoweek(Fecha_Completa),
Es_fin_semana = Dia_semana %in% c("Sábado", "Domingo"),
Es_noche = Hora_num >= 22 | Hora_num < 6,
Es_movil = str_detect(str_to_lower(Origen), "mobile|móvil|movil|app")
)
eventos_profesor_estricto <- c(
"Sección del curso creada",
"Módulo de curso creado",
"Módulo de curso actualizado"
)
profesores_ids <- logs %>%
filter(Nombre.evento %in% eventos_profesor_estricto) %>%
distinct(Nombre.completo.del.usuario) %>%
pull()
alumnos_ids <- logs %>%
filter(!Nombre.completo.del.usuario %in% profesores_ids) %>%
distinct(Nombre.completo.del.usuario) %>%
pull()
logs_profesores <- logs %>% filter(Nombre.completo.del.usuario %in% profesores_ids)
logs_alumnos <- logs %>% filter(Nombre.completo.del.usuario %in% alumnos_ids)
resumen_estructura <- tibble(
dataset = c("Total", "Profesores", "Alumnos"),
registros = c(nrow(logs), nrow(logs_profesores), nrow(logs_alumnos)),
usuarios = c(
n_distinct(logs$Nombre.completo.del.usuario),
n_distinct(logs_profesores$Nombre.completo.del.usuario),
n_distinct(logs_alumnos$Nombre.completo.del.usuario)
)
)
knitr::kable(resumen_estructura,
booktabs = TRUE,
caption = "Resumen de la estructura y segmentación del dataset según el rol operativo") %>%
kableExtra::kable_styling(latex_options = c("striped", "hold_position"))
tlmgr option repository http://mirror.ctan.org/systems/texlive/tlnet
tlmgr option repository http://mirror.ctan.org/systems/texlive/tlnet
tinytex::tlmgr(c("option", "repository", "http://mirror.ctan.org/systems/texlive/tlnet"))
tinytex::tlmgr_update()
tinytex::tlmgr_install("babel-spanish")
tinytex::tlmgr_repo("http://mirror.ctan.org/systems/texlive/tlnet")
tinytex::tlmgr_install("babel-spanish")
tinytex::tlmgr_repo("https://mirror.ctan.org/systems/texlive/tlnet")
tinytex::tlmgr_update()
tinytex::tlmgr_install("babel-spanish")
tinytex::uninstall_tinytex()
tinytex::install_tinytex()
tinytex::tlmgr_repo("https://ctan.org/systems/texlive/tlnet")
tinytex::tlmgr_install(c("babel-spanish", "hyphen-spanish", "kableExtra", "booktabs", "graphics", "amsmath"))
tinytex::tlmgr(c("install", "babel-spanish", "hyphen-spanish", "kableExtra", "booktabs", "amsmath", "--repository", "https://mirror.ctan.org/systems/texlive/tlnet"))
paquetes <- c("multirow", "wrapfig", "colortbl", "tabu", "threeparttable", "threeparttablex", "environ", "tcolorbox", "makecell")
for(p in paquetes){
tinytex::tlmgr(c("install", p, "--repository", "https://mirror.ctan.org/systems/texlive/tlnet"))
}
pendientes <- c("pdflscape", "utilidos", "letltxmacro", "ms", "scheme-basic", "xcolor")
for(p in pendientes){
tinytex::tlmgr(c("install", p, "--repository", "https://mirror.ctan.org/systems/texlive/tlnet"))
}
library(tidyverse)
library(lubridate)
library(knitr)
options(OutDec = ",", digits = 3)
knitr::opts_chunk$set(echo = FALSE, warning = FALSE, message = FALSE)
logs_raw <- read.csv("data/logs_moodle_anon.csv", sep = ",", stringsAsFactors = FALSE)
logs <- logs_raw %>%
mutate(
Fecha_Completa = dmy_hms(Hora),
Solo_Fecha = as.Date(Fecha_Completa),
Hora_num = hour(Fecha_Completa),
Dia_semana_num = wday(Fecha_Completa, week_start = 1),
Dia_semana = factor(
c("Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")[Dia_semana_num],
levels = c("Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
),
Semana = isoweek(Fecha_Completa),
Es_fin_semana = Dia_semana %in% c("Sábado", "Domingo"),
Es_noche = Hora_num >= 22 | Hora_num < 6,
Es_movil = str_detect(str_to_lower(Origen), "mobile|móvil|movil|app")
)
eventos_profesor_estricto <- c(
"Sección del curso creada",
"Módulo de curso creado",
"Módulo de curso actualizado"
)
profesores_ids <- logs %>%
filter(Nombre.evento %in% eventos_profesor_estricto) %>%
distinct(Nombre.completo.del.usuario) %>%
pull()
alumnos_ids <- logs %>%
filter(!Nombre.completo.del.usuario %in% profesores_ids) %>%
distinct(Nombre.completo.del.usuario) %>%
pull()
logs_profesores <- logs %>% filter(Nombre.completo.del.usuario %in% profesores_ids)
logs_alumnos <- logs %>% filter(Nombre.completo.del.usuario %in% alumnos_ids)
resumen_estructura <- tibble(
dataset = c("Total", "Profesores", "Alumnos"),
registros = c(nrow(logs), nrow(logs_profesores), nrow(logs_alumnos)),
usuarios = c(
n_distinct(logs$Nombre.completo.del.usuario),
n_distinct(logs_profesores$Nombre.completo.del.usuario),
n_distinct(logs_alumnos$Nombre.completo.del.usuario)
)
)
knitr::kable(resumen_estructura,
booktabs = TRUE,
caption = "Resumen de la estructura y segmentación del dataset según el rol operativo") %>%
kableExtra::kable_styling(latex_options = c("striped", "hold_position"))
# Instalamos ulem (el que te pide ahora) y otros básicos para que no falle más
servidor <- "https://mirror.ctan.org/systems/texlive/tlnet"
paquetes_finales <- c("ulem", "pdflscape", "latex-amsmath-dev", "lambdax", "xcolor", "knitr")
for(p in paquetes_finales){
tinytex::tlmgr(c("install", p, "--repository", servidor))
}
